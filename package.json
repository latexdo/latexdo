{
  "name": "latexdo",
  "version": "0.1.0",
  "private": true,
  "description": "A focused desktop LaTeX editor with live PDF preview.",
  "author": "LatexDo",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "web": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json",
    "start": "electron .",
    "sync:downstream": "sh scripts/sync-downstream-repos.sh",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.electron.json --pretty false",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:diagnostics": "node --experimental-strip-types scripts/test-latex-diagnostics.ts",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "bibtex-parse-js": "^0.0.24",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.0.5",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.latexdo.editor",
    "productName": "LatexDo",
    "icon": "build/icon.png",
    "npmRebuild": true,
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "examples/welcome",
        "to": "examples/welcome"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true,
      "extendInfo": {
        "NSDocumentsFolderUsageDescription": "LatexDo needs access to open and save LaTeX projects in your Documents folder.",
        "NSDownloadsFolderUsageDescription": "LatexDo needs access to export generated PDFs and project files to Downloads."
      }
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "category": "Office",
      "target": [
        "AppImage"
      ]
    }
  }
}
